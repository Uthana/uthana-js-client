{
  "name": "@uthana/react",
  "version": "0.2.0",
  "description": "React and react-query hooks for the Uthana API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "dev": "rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript --watch",
    "test": "vitest run --root ../.. tests/test_hooks"
  },
  "dependencies": {
    "@uthana/client": "file:../client",
    "@tanstack/react-query": "^5.62.0",
    "graffle": "next",
    "graphql": "^16.9.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "keywords": [
    "uthana",
    "react",
    "react-query",
    "graphql",
    "motion"
  ],
  "license": "Apache-2.0"
}
