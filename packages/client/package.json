{
  "name": "@uthana/client",
  "version": "1.0.0",
  "description": "Uthana API client for JavaScript and TypeScript — works in browser and Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "graffle": "next",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "uthana",
    "graphql",
    "motion",
    "animation",
    "3d"
  ],
  "license": "Apache-2.0"
}
