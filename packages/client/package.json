{
  "name": "@uthana/client",
  "version": "1.1.0-rc.0",
  "description": "Uthana API client for JavaScript and TypeScript — works in browser and Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "dev": "rollup -c rollup.config.ts --configPlugin @rollup/plugin-typescript --watch"
  },
  "peerDependencies": {
    "graffle": "next",
    "graphql": "^16.9.0"
  },
  "peerDependenciesMeta": {
    "graffle": { "optional": false },
    "graphql": { "optional": false }
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "keywords": [
    "uthana",
    "graphql",
    "motion",
    "animation",
    "3d"
  ],
  "license": "Apache-2.0"
}
