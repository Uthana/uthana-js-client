{
  "name": "@uthana/client",
  "version": "0.3.0",
  "description": "Uthana API client for JavaScript and TypeScript — works in browser and Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "dev": "rollup -c rollup.config.mjs --watch",
    "test": "vitest run --root ../.. tests/test_modules tests/test_jobs_wait tests/test_ttm_mapping tests/test_unit tests/test_utils",
    "test:integration": "vitest run --root ../.. tests/test_client"
  },
  "peerDependencies": {
    "graffle": "next",
    "graphql": "^16.9.0"
  },
  "peerDependenciesMeta": {
    "graffle": {
      "optional": false
    },
    "graphql": {
      "optional": false
    }
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "keywords": [
    "uthana",
    "graphql",
    "motion",
    "animation",
    "3d"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Uthana/uthana-js-client.git",
    "directory": "packages/client"
  }
}
