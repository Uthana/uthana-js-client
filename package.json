{
  "name": "uthana-monorepo",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "version": "0.2.1-rc.0",
  "description": "Uthana JS/TS client monorepo",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "codegen": "npx graffle",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/test_client*'",
    "test:integration": "vitest run tests/test_client",
    "test:coverage": "vitest run --coverage --exclude '**/test_client*'",
    "sync-versions": "node scripts/sync-versions.mjs",
    "prepare": "npm run sync-versions && npm run build && husky",
    "publish": "node scripts/publish-packages.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@testing-library/react": "^16.3.2",
    "@vitest/coverage-v8": "^2.1.9",
    "dotenv": "^16.4.5",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "graffle": "next",
    "graphql": "^16.9.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "rollup": "^4.28.1",
    "rollup-plugin-dts": "^6.1.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.6"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  }
}
